generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String
  createdAt DateTime   @default(now())
  recipes   Recipe[]
  cartItems CartItem[]
}

model Recipe {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  time        String
  servings    Int
  ingredients String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
}

model CartItem {
  id          Int      @id @default(autoincrement())
  recipeId    Int
  recipeTitle String
  ingredients String[]
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
}
